{
    "layer": "top",
    "position": "bottom",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 0,
    "modules-left": ["clock", "custom/weather", "hyprland/workspaces", "custom/wallpaper-engine"],
    //"modules-center": ["hyprland/window"],
    "modules-right": ["backlight","pulseaudio","pulseaudio#microphone","tray","battery","custom/wlogout"],
    "hyprland/window": {
        "format": "{}"
    },

   "hyprland/workspaces": {
        "disable-scroll": true,
        "on-scroll-up": "hyprctl dispatch workspace -1",
        "on-scroll-down": "hyprctl dispatch workspace +1",
		"format": "{name}: {windows}",
		"on-click": "activate",
		"format-icons": {
//			"1": "õ©Ç",
//			"2": "õ║î",
//			"3": "õ©ë",
//			"4": "Õøø",
//			"5": "õ║ö",
			"urgent": "´ü¬",
			//"active": "¾▒ô╗¾░Øñ¾▒ô╗",
			"active": "",
			//"default": "¾▒ô╗"
			"default": ""
		},

/*    	"sort-by-number": true,*/
    	"persistent-workspaces": {
    	         "*": 5
        },

        "window-rewrite-default": "¾▒ô╗",
	    "window-rewrite": {
		    "title<.*youtube.*>": "´à¬", // Windows whose titles contain "youtube"
		    //"class<firefox>": "´ë®", // Windows whose classes are "firefox"
		    "class<none>": "r", // Windows whose classes are "firefox"
		    "class<librewolf>": "¾░ê╣", // Windows whose classes are "firefox"
		    "class<librewolf> title<.*github.*>": "´äô", // Windows whose class is "firefox" and title contains "github". Note that "class" always comes first.
		    "alacritty": "¯Şò", // Windows that contain "foot" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
		    "ghostty": "¯Şò", // Windows that contain "foot" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
		    "thunar": "¾▒ğÂ", // Windows that contain "foot" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
		    "code": "¾░¿Ş",
		    "slack": "¯óñ",
		    "youtube-music": "¾░Äå",
            "spotify": "\uf1bc",
            "discord": "\uf1ff",
            "Brave-browser-beta": "¾░ûş", 
            "wofi": "´Éó",
            "gimp": "´î©", 
            "obsidian": "¾▒Şü",
            "notion": "¯íê",
            "com.stremio.stremio": "¾░┐Å",
            "title<*chatgpt.*>": "¾░Ü®",
            "title<openai*>": "¾░Ü®",
            "title<*outlook*>": "¾░┤ó",
            "Minecraft*": "¾░ı│",
            "Mattermost": "¯║┐",
		    "title<.* - (.*) - VSCodium>": "codium $1"  // captures part of the window title and formats it into output
	    }
    },

/*
    "wlr/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
