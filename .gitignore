# OS/editor junk
*.swp
*.swo
*~
.DS_Store

# secrets — never commit these
*.pem
*.key
id_*
.ssh/

# caches
.cache/
__pycache__/
*.pyc

# stow internal
.stow-local-ignore

# large stuff that shouldn't be in git
*.zip
*.tar.*
node_modules/

# wallpapers — synced from server via sync-wallpapers.sh, not in git
wallpapers/

# private folder — now its own git repo on Gitea
private/

# machine-specific monitor config (each host owns this file locally)
hypr/.config/hypr/monitors.conf
hypr/.config/hypr/workspaces.conf

# tmux plugins — installed at runtime by TPM (prefix + I)
tmux/.config/tmux/plugins/

# backup files
*.bak

# font cache (auto-generated by fontconfig)
fontconfig/.config/fontconfig/*.cache*
